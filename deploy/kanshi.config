# deploy/kanshi.config
# Managed kanshi profile for the in-cab DSI panel (labwc + kanshi 1.5).
# pull-deploy.sh installs this to ~/.config/kanshi/config (and config.init) on
# every deploy, so the panel's rotation/mode is version-controlled and survives
# a reimage. kanshi applies it on every boot; pull-deploy also applies it live.
#
# To rotate the screen, change `transform` and let it deploy:
#   normal | 90 | 180 (upside-down) | 270
# Do NOT hand-edit ~/.config/kanshi/config on the Pi — pull-deploy overwrites it.
profile {
	output DSI-2 enable scale 1.000000 mode 800x480@60.029 position 0,0 transform 180
}

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.mav_env/
.mav_tel_hub/
mav_tel_hub/

# Pip and wheel caches
pip-wheel-metadata/
pip-selfcheck.json

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Pytest and coverage
.pytest_cache/
.coverage
htmlcov/

# SQLite databases
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
db/*.db

# Vision snapshots (JPEGs written by db_writer; dev default is <repo>/snapshots)
snapshots/

# Model weights/engines — never in git (see jetson/models/README.md)
*.pt
*.engine
*.onnx

# Training datasets never belong in the repo (see jetson/training/README.md);
# ultralytics is configured to use C:\datasets, but guard the repo root too.
/datasets/

# Environment variables / secrets
.env
.env.*

# Logs
logs/
*.log

# Node
node_modules/
server/node_modules/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# IDE / editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Misc
*.swp
*~
